# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/zapi?retryWrites=true&w=majority

# Twilio WhatsApp Integration
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=+1234567890

# Authentication
JWT_SECRET=your_super_secret_jwt_key_change_in_production

# OpenAI (for AI-powered intent extraction)
OPENAI_API_KEY=sk-your_openai_api_key_here

# Stripe Payment Processing
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# Upstash Redis (for session state management & slot locking)
# Sign up at https://upstash.com/ for free tier
REDIS_URL=https://your-redis-instance.upstash.io
REDIS_TOKEN=your_redis_token_here

# Resend Email Service
# Sign up at https://resend.com/ for free tier
RESEND_API_KEY=re_your_resend_api_key

# Monei Payment Processing (Optional - Alternative to Stripe)
MONEI_API_KEY=your_monei_api_key
MONEI_WEBHOOK_SECRET=your_monei_webhook_secret
